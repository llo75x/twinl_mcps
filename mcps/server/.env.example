# =============================================================================
# Modèle d'environnement pour UNE instance du serveur MCP read-only.
# Copier en `mcps/iafec.env` et `mcps/projea.env` SUR LE VPS (jamais commité ;
# chmod 600). Ne JAMAIS mettre de vraie valeur ici (règle iafec/OPS.md §3.5).
# =============================================================================

# ── Identité de l'instance ───────────────────────────────────────────────────
MCP_SERVER_NAME=mcp-iafec-readonly
MCP_PORT=8080                       # port interne conteneur (mappé 127.0.0.1:80xx par compose)

# ── Instructions du serveur (règles métier + data model, PAR INSTANCE) ────────
# Champ MCP standard lu automatiquement par tout client (claude.ai web, Claude Desktop,
# Cowork, Claude Code). Pointe vers le fichier monté en lecture seule par docker-compose
# (cf. volumes: ./instructions/<nom>.md → /app/instructions.md). Vide = aucune instruction.
MCP_INSTRUCTIONS_FILE=/app/instructions.md

# ── Base miroir read-only (réutilise l'existant — voir 1Password) ─────────────
MCP_DB_HOST=host.docker.internal    # MariaDB tourne sur l'HÔTE (extra_hosts host-gateway)
MCP_DB_PORT=3306
MCP_DB_USER=CHANGE_ME_readonly      # ex. iaFEC_readonly / projea_readonly
MCP_DB_PASS=CHANGE_ME_PASSWORD      # password du user RO (1Password / *.local.sql)
MCP_DB_NAME=CHANGE_ME_readonly_db   # ex. iafec_readonly / twinl_readonly

# ── OAuth WorkOS AuthKit ──────────────────────────────────────────────────────
AUTHKIT_DOMAIN=https://CHANGE_ME.authkit.app
BASE_URL=https://mcp-iafec.twinl.fr # URL publique de CETTE instance (= resource indicator)

# ── Plafonds réponse (anti-saturation RAM conteneur / contexte Claude) ────────
MCP_MAX_ROWS=1000
MCP_MAX_BYTES=1000000
MCP_STMT_TIMEOUT_S=20               # MariaDB max_statement_time (secondes)

# ── Filet secondaire d'identité (la garde primaire est l'invite-only WorkOS) ──
# Liste d'emails/sub autorisés, séparés par des virgules. Vide = confiance à WorkOS seul.
MCP_ALLOWED_SUBJECTS=

# ── Notification Slack (optionnel) ───────────────────────────────────────────
# Envoie une alerte dans un canal Slack quand une requête retourne plus de
# SLACK_NOTIFY_THRESHOLD lignes. Utiliser un Incoming Webhook Slack (api.slack.com/apps).
# Vide = notifications désactivées.
SLACK_WEBHOOK_URL=
SLACK_NOTIFY_THRESHOLD=200

# ── Mot de passe de confirmation pour extractions volumineuses (optionnel) ────
# Si défini, toute requête retournant plus de SLACK_NOTIFY_THRESHOLD lignes exige
# ce mot de passe via le paramètre `extract_password` de mysql_query.
# Vide = aucune confirmation requise (comportement précédent).
MCP_EXTRACT_PASSWORD=
